{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "harness-kit render output",
  "$defs": {
    "output": {
      "type": "object",
      "required": [
        "$schema",
        "contract_version",
        "run_id",
        "stage",
        "produced_at",
        "data"
      ],
      "properties": {
        "$schema": {
          "const": "render.schema.json#/$defs/output"
        },
        "contract_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "run_id": {
          "type": "string",
          "format": "uuid"
        },
        "stage": {
          "const": "render"
        },
        "produced_at": {
          "type": "string",
          "format": "date-time"
        },
        "data": {
          "$ref": "#/$defs/render-data"
        }
      },
      "additionalProperties": false
    },
    "rendered-file": {
      "type": "object",
      "required": [
        "path",
        "action",
        "sha256_preview"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
        },
        "action": {
          "enum": [
            "created",
            "updated",
            "skipped",
            "refused"
          ]
        },
        "sha256_preview": {
          "type": "string",
          "maxLength": 16
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "render-data": {
      "type": "object",
      "required": [
        "status",
        "target_file",
        "files",
        "collision_policy"
      ],
      "properties": {
        "status": {
          "enum": [
            "OK",
            "INSUFFICIENT_EVIDENCE",
            "ERROR",
            "BLOCKED"
          ]
        },
        "target_file": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rendered-file"
          }
        },
        "collision_policy": {
          "enum": [
            "refuse",
            "merge",
            "force",
            "versioned"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "$comment": "Replace $id at publish with: https://raw.githubusercontent.com/<owner>/harness-kit/<ref>/schemas/render.schema.json"
}
